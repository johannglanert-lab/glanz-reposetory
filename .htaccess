# ════════════════════════════════════════════════════════════════════
# GLANZ DESIGN — Hauptdomain (glanzdesign.eu) — Webserver-Konfiguration
# ════════════════════════════════════════════════════════════════════

# ── Security Headers ────────────────────────────────────────────────
# Werden auf jede ausgelieferte Antwort gesetzt.
<IfModule mod_headers.c>
    # HSTS: erzwingt HTTPS für 1 Jahr inkl. Subdomains (preload möglich).
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"

    # Verhindert Clickjacking (Einbindung der Seite per <iframe>).
    Header always set X-Frame-Options "SAMEORIGIN"

    # Verhindert MIME-Type-Sniffing.
    Header always set X-Content-Type-Options "nosniff"

    # Begrenzt Referrer-Informationen auf gleiche Origin.
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # Deaktiviert Browser-APIs, die wir nicht nutzen.
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=(), interest-cohort=()"

    # Cross-Origin-Opener / Resource Policies — sichere Defaults.
    Header always set Cross-Origin-Opener-Policy "same-origin"
    Header always set Cross-Origin-Resource-Policy "same-site"

    # Content Security Policy — strikt:
    # - keine externen Skripte, kein eval (nur inline-script via 'unsafe-inline' wegen Preloader)
    # - Fonts/CSS/Bilder nur von eigener Origin und data: URIs
    # - Formular-Submits nur auf eigene Origin
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self'; form-action 'self'; frame-ancestors 'self'; base-uri 'self'; object-src 'none'; upgrade-insecure-requests"

    # X-XSS-Protection ist veraltet (durch CSP ersetzt) — nicht setzen.
</IfModule>

# ── Schutz sensibler Dateien ────────────────────────────────────────
# .htaccess, .git, .env etc. niemals ausliefern.
<FilesMatch "^\.(htaccess|htpasswd|env|git.*|DS_Store)$|~$|\.bak$|\.swp$|\.log$">
    Require all denied
</FilesMatch>

# Markdown-/PHP-Konfig-Dateien nicht direkt herausgeben.
<FilesMatch "\.(md|sql|conf|ini)$">
    Require all denied
</FilesMatch>

# ── HTML nicht cachen ───────────────────────────────────────────────
# Cache-Busting der JS-Versionen (?v=N) wirkt nur, wenn der Browser
# frisches HTML lädt. Sonst sieht der Browser den neuen Versionsstring
# nie und serviert die alte JS aus dem Disk-Cache weiter.
<IfModule mod_headers.c>
    <FilesMatch "\.(html|htm)$">
        Header set Cache-Control "no-cache, must-revalidate"
        Header set Pragma "no-cache"
    </FilesMatch>
</IfModule>

# ── Lange Cache-Zeiten für statische Assets ─────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
</IfModule>

# ── Verzeichnis-Listing deaktivieren ────────────────────────────────
Options -Indexes

# ── Server-Signatur ausblenden ──────────────────────────────────────
ServerSignature Off
